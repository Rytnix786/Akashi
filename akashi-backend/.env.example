# ─── Sentinel Hub Credentials ─────────────────────────────────────────────────
# Get these from: https://apps.sentinel-hub.com/dashboard → User Settings → OAuth Clients
SENTINEL_HUB_CLIENT_ID=your_client_id_here
SENTINEL_HUB_CLIENT_SECRET=your_client_secret_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ─── Firebase (FCM) ───────────────────────────────────────────────────────────
# Path to your Firebase service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ─── Weather API ──────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
API_SECRET_KEY=change_this_to_a_random_secret_in_production
